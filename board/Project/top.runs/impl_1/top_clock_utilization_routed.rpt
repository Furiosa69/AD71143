# Location of BUFG Primitives 
set_property LOC BUFGCTRL_X0Y4 [get_cells sys_clk_IBUF_BUFG_inst]
set_property LOC BUFGCTRL_X0Y1 [get_cells rgmii_txc_OBUF_BUFG_inst]
set_property LOC BUFGCTRL_X0Y2 [get_cells cap_bit_cnt_dclko_reg[6]_i_3]
set_property LOC BUFGCTRL_X0Y0 [get_cells clk_200m_BUFG_inst]
set_property LOC BUFGCTRL_X0Y3 [get_cells clk_100m_BUFG_inst]

# Location of IO Primitives which is load of clock spine
set_property LOC IOB_X1Y176 [get_cells rgmii_txc_OBUF_inst]

# Location of clock ports
set_property LOC IOB_X1Y127 [get_ports dclko_n_A]
set_property LOC IOB_X1Y128 [get_ports dclko_p_A]
set_property LOC IOB_X1Y124 [get_ports sys_clk]

# Clock net "sys_clk_IBUF_BUFG" driven by instance "sys_clk_IBUF_BUFG_inst" located at site "BUFGCTRL_X0Y4"
#startgroup
create_pblock {CLKAG_sys_clk_IBUF_BUFG}
add_cells_to_pblock [get_pblocks  {CLKAG_sys_clk_IBUF_BUFG}] [get_cells -filter { PRIMITIVE_GROUP != I/O && IS_PRIMITIVE==1 && PRIMITIVE_LEVEL !=INTERNAL && NAME!=u_rgmii_bridge/mmcm_inst && NAME!=pll_inst} -of_object [get_pins -filter {DIRECTION==IN} -of_objects [get_nets -hierarchical -filter {PARENT=="sys_clk_IBUF_BUFG"}]]]
resize_pblock [get_pblocks {CLKAG_sys_clk_IBUF_BUFG}] -add {CLOCKREGION_X0Y2:CLOCKREGION_X0Y2 CLOCKREGION_X0Y3:CLOCKREGION_X0Y3}
#endgroup

# Clock net "rgmii_txc_OBUF_BUFG" driven by instance "rgmii_txc_OBUF_BUFG_inst" located at site "BUFGCTRL_X0Y1"
#startgroup
create_pblock {CLKAG_rgmii_txc_OBUF_BUFG}
add_cells_to_pblock [get_pblocks  {CLKAG_rgmii_txc_OBUF_BUFG}] [get_cells -filter { PRIMITIVE_GROUP != I/O && IS_PRIMITIVE==1 && PRIMITIVE_LEVEL !=INTERNAL && NAME!=rgmii_txc_OBUF_inst} -of_object [get_pins -filter {DIRECTION==IN} -of_objects [get_nets -hierarchical -filter {PARENT=="rgmii_txc_OBUF_BUFG"}]]]
resize_pblock [get_pblocks {CLKAG_rgmii_txc_OBUF_BUFG}] -add {CLOCKREGION_X0Y2:CLOCKREGION_X0Y2 CLOCKREGION_X0Y3:CLOCKREGION_X0Y3 CLOCKREGION_X1Y3:CLOCKREGION_X1Y3}
#endgroup

