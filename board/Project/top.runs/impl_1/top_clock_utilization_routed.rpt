# Location of BUFG Primitives 
set_property LOC BUFGCTRL_X0Y2 [get_cells sys_clk_IBUF_BUFG_inst]
set_property LOC BUFGCTRL_X0Y3 [get_cells gate_clk_BUFG_inst]
set_property LOC BUFGCTRL_X0Y1 [get_cells dclko_p_A_IBUF_BUFG_inst]
set_property LOC BUFGCTRL_X0Y0 [get_cells clk_200m_BUFG_inst]

# Location of IO Primitives which is load of clock spine

# Location of clock ports
set_property LOC IOB_X0Y78 [get_ports dclko_p_A]
set_property LOC IOB_X1Y124 [get_ports sys_clk]

# Clock net "sys_clk_IBUF_BUFG" driven by instance "sys_clk_IBUF_BUFG_inst" located at site "BUFGCTRL_X0Y2"
#startgroup
create_pblock {CLKAG_sys_clk_IBUF_BUFG}
add_cells_to_pblock [get_pblocks  {CLKAG_sys_clk_IBUF_BUFG}] [get_cells -filter { PRIMITIVE_GROUP != I/O && IS_PRIMITIVE==1 && PRIMITIVE_LEVEL !=INTERNAL } -of_object [get_pins -filter {DIRECTION==IN} -of_objects [get_nets -hierarchical -filter {PARENT=="sys_clk_IBUF_BUFG"}]]]
resize_pblock [get_pblocks {CLKAG_sys_clk_IBUF_BUFG}] -add {CLOCKREGION_X0Y2:CLOCKREGION_X0Y2}
#endgroup

# Clock net "gate_clk_BUFG" driven by instance "gate_clk_BUFG_inst" located at site "BUFGCTRL_X0Y3"
#startgroup
create_pblock {CLKAG_gate_clk_BUFG}
add_cells_to_pblock [get_pblocks  {CLKAG_gate_clk_BUFG}] [get_cells -filter { PRIMITIVE_GROUP != I/O && IS_PRIMITIVE==1 && PRIMITIVE_LEVEL !=INTERNAL } -of_object [get_pins -filter {DIRECTION==IN} -of_objects [get_nets -hierarchical -filter {PARENT=="gate_clk_BUFG"}]]]
resize_pblock [get_pblocks {CLKAG_gate_clk_BUFG}] -add {CLOCKREGION_X0Y2:CLOCKREGION_X0Y2}
#endgroup

# Clock net "dclko_p_A_IBUF_BUFG" driven by instance "dclko_p_A_IBUF_BUFG_inst" located at site "BUFGCTRL_X0Y1"
#startgroup
create_pblock {CLKAG_dclko_p_A_IBUF_BUFG}
add_cells_to_pblock [get_pblocks  {CLKAG_dclko_p_A_IBUF_BUFG}] [get_cells -filter { PRIMITIVE_GROUP != I/O && IS_PRIMITIVE==1 && PRIMITIVE_LEVEL !=INTERNAL } -of_object [get_pins -filter {DIRECTION==IN} -of_objects [get_nets -hierarchical -filter {PARENT=="dclko_p_A_IBUF_BUFG"}]]]
resize_pblock [get_pblocks {CLKAG_dclko_p_A_IBUF_BUFG}] -add {CLOCKREGION_X0Y2:CLOCKREGION_X0Y2}
#endgroup

# Clock net "clk_200m_BUFG" driven by instance "clk_200m_BUFG_inst" located at site "BUFGCTRL_X0Y0"
#startgroup
create_pblock {CLKAG_clk_200m_BUFG}
add_cells_to_pblock [get_pblocks  {CLKAG_clk_200m_BUFG}] [get_cells -filter { PRIMITIVE_GROUP != I/O && IS_PRIMITIVE==1 && PRIMITIVE_LEVEL !=INTERNAL } -of_object [get_pins -filter {DIRECTION==IN} -of_objects [get_nets -hierarchical -filter {PARENT=="clk_200m_BUFG"}]]]
resize_pblock [get_pblocks {CLKAG_clk_200m_BUFG}] -add {CLOCKREGION_X0Y1:CLOCKREGION_X0Y1 CLOCKREGION_X0Y2:CLOCKREGION_X0Y2 CLOCKREGION_X1Y2:CLOCKREGION_X1Y2}
